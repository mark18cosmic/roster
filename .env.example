# ─────────────────────────────────────────────────────────────
# Roster environment configuration
# Copy to `.env` and adjust. `.env` is gitignored.
# The same file drives on-prem (LAN) and cloud deployments — the
# only thing that differs is SYNC_MODE and the public host.
# ─────────────────────────────────────────────────────────────

# --- Deployment identity ---
NODE_ENV=development

# --- Database (Postgres) ---
POSTGRES_USER=roster
POSTGRES_PASSWORD=roster_dev_password
POSTGRES_DB=roster
POSTGRES_PORT=5432
# Consumed by the api container. Host is the compose service name `db`.
DATABASE_URL=postgres://roster:roster_dev_password@db:5432/roster

# --- API service ---
API_PORT=8080
# Public origin the browser uses to reach the api (CORS + web fetches).
API_PUBLIC_URL=http://localhost:8080

# --- Web service (Next.js) ---
WEB_PORT=3000
# Baked into the web build / used by the browser to call the api.
NEXT_PUBLIC_API_URL=http://localhost:8080

# --- Auth (JWT) ---
# Generate a strong secret for real deployments, e.g. `openssl rand -hex 32`.
JWT_SECRET=change_me_dev_only_secret
JWT_EXPIRES_IN=12h

# ─────────────────────────────────────────────────────────────
# Device sync configuration
# ─────────────────────────────────────────────────────────────

# push = device calls our /iclock/* endpoints (ADMS). Use in cloud, or on-prem
#        where the device is configured to talk to us.
# poll = our backend connects to the device on TCP 4370 (ZK binary protocol).
#        Use on-prem where we can reach the device directly.
SYNC_MODE=push

# --- Push mode: ADMS listener ---
# Shared secret the device must present (?key=... on /iclock requests).
# Devices are additionally validated against the `devices` table by serial (SN).
# Leave blank to disable the shared-key check (serial allowlist still applies).
ADMS_SHARED_KEY=change_me_dev_only_key

# --- Poll mode: ZK worker ---
# How often (seconds) the poll worker connects to each device to pull new logs.
POLL_INTERVAL_SECONDS=30
# Default device TCP port for the ZK binary protocol.
ZK_DEVICE_PORT=4370

# --- Device health ---
# A device is considered offline if no heartbeat/contact within this window.
DEVICE_OFFLINE_THRESHOLD_SECONDS=300

# ─────────────────────────────────────────────────────────────
# Mock ADMS simulator (dev/testing only — no hardware required)
# ─────────────────────────────────────────────────────────────
# Where the simulator sends its fake punches (the api's push listener).
SIM_TARGET_URL=http://localhost:8080
# Serial the simulator identifies as. Must exist in the `devices` table
# (see the seed script) for the push listener to accept it.
SIM_DEVICE_SERIAL=MB20VL-SIM-0001
SIM_SHARED_KEY=change_me_dev_only_key
